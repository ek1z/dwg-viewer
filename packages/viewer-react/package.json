{
  "name": "@dwg-viewer/viewer-react",
  "version": "0.0.0",
  "type": "module",
  "comment": "Internal workspace package: exports point at TS source (see dxf-core).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "echo 'viewer-react is consumed from source by the Astro app; no standalone build'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dwg-viewer/dxf-core": "workspace:*",
    "@dwg-viewer/measure": "workspace:*",
    "@dwg-viewer/viewer-engine": "workspace:*",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  }
}
