{
  "name": "@dwg-viewer/dxf-core",
  "version": "0.0.0",
  "type": "module",
  "comment": "Internal workspace package: exports point at TS source so Vite/Astro transpiles on the fly (no build step in dev). `pnpm build` produces dist/ for standalone consumption.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dxf-parser": "^1.1.2"
  },
  "devDependencies": {
    "tsdown": "^0.22.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  }
}
