{
  "name": "@dwg-viewer/dwg-core",
  "version": "0.0.0",
  "type": "module",
  "comment": "DWG input (Phase 3). Converts DWG to DXF in-browser via the libredwg WASM, then reuses dxf-core's scene pipeline. The GPL-licensed WASM is isolated here so dxf-core stays pure and license-clean.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dwg-viewer/dxf-core": "workspace:*",
    "@mlightcad/libredwg-web": "^0.7.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  }
}
