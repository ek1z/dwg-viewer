{
  "name": "@dwg-viewer/viewer-engine",
  "version": "0.0.0",
  "type": "module",
  "comment": "Internal workspace package: exports point at TS source (see dxf-core).",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dwg-viewer/dxf-core": "workspace:*",
    "@dwg-viewer/measure": "workspace:*",
    "three": "^0.184.0",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.9"
  }
}
